---
import type { Lang } from '../i18n/config.i18n';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
    title: string;
    lang: Lang;
    description?: string;
    image?: string;
    schema?: object;
    canonicalPath?: string;
}

const { 
    title, 
    lang, 
    description = "Cancun Drink - Soluciones profesionales de limpieza y mantenimiento.", 
    image = "/logo_cancun.png", 
    schema,
    canonicalPath
} = Astro.props;

const baseUrl = "https://cancundrink.com";
const currentPath = canonicalPath ?? Astro.url.pathname;
const normalizedPath = currentPath.startsWith('/') ? currentPath : `/${currentPath}`;
const canonicalURL = new URL(normalizedPath, baseUrl).href;

const esPath = normalizedPath.replace(/^\/en(?=\/|$)/, '/es');
const enPath = normalizedPath.replace(/^\/es(?=\/|$)/, '/en');

const esURL = new URL(esPath, baseUrl).href;
const enURL = new URL(enPath, baseUrl).href;
const socialImageURL = new URL(image, Astro.url.origin).href;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#ffffff" /> <link rel="icon" type="image/png" href="/icono_cancun.png" />
        
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index, follow" />

        <link rel="canonical" href={canonicalURL} />
        <link rel="alternate" hreflang="es" href={esURL} />
        <link rel="alternate" hreflang="en" href={enURL} />
        <link rel="alternate" hreflang="x-default" href={baseUrl} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:site_name" content="Cancun Drink" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={title} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalURL} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImageURL} />

        <meta name="apple-mobile-web-app-title" content="Cancun Drink" />
        <meta name="application-name" content="Cancun Drink" />

        <ClientRouter />

        {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    </head>
    <body class="bg-white text-gray-900 antialiased">
        <Navbar lang={lang} />
        <main>
            <slot /> 
        </main>
        <Footer lang={lang} />
    </body>
</html>

<style is:global>
    html {
        scroll-behavior: smooth;
    }
    ::view-transition-old(root),
    ::view-transition-new(root) {
        animation-duration: 0.4s;
    }
</style>