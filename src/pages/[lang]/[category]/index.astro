---
import Layout from '../../../layouts/Layout.astro';
import content from '../../../data/site-categories-content.json';
import type { Lang } from '../../../i18n/config.i18n';
import Questions from '../../../components/home/sections/Questions.astro';
import HeroCategory from '../../../components/category/sections/HeroCategory.astro';

const lang = Astro.params.lang as Lang;
const category = Astro.params.category as string;
const data = content[lang].categories.categories.find(c => c.slugs.includes(category));

if (!(lang in content)) {
    return Astro.redirect('/404');
}
import 'aos/dist/aos.css';
import { actions } from 'astro:actions';
import Products from '../../../components/category/sections/Products.astro';

const { data: products, error: errorProducts } = await Astro.callAction(actions.getProductsForCategory, { category });

if (!data) {
    return Astro.redirect('/404');
}

const pageTitle = `${data.title} | Cancun Drink`;
const pageDescription = data.description;
const pageImage = data.image_pc;

const schema = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'CollectionPage',
            name: pageTitle,
            description: pageDescription,
            inLanguage: lang,
            url: `https://cancundrink.com/${lang}/${category}`,
            image: `https://cancundrink.com${pageImage}`
        },
        {
            '@type': 'BreadcrumbList',
            itemListElement: [
                {
                    '@type': 'ListItem',
                    position: 1,
                    name: lang === 'es' ? 'Inicio' : 'Home',
                    item: `https://cancundrink.com/${lang}/`
                },
                {
                    '@type': 'ListItem',
                    position: 2,
                    name: data.title,
                    item: `https://cancundrink.com/${lang}/${category}`
                }
            ]
        },
        {
            '@type': 'ItemList',
            name: data.title,
            itemListElement: (products?.data ?? []).map((product, index) => ({
                '@type': 'ListItem',
                position: index + 1,
                name: product.name,
                url: `https://cancundrink.com/${lang}/${category}/${product.slug}`
            }))
        }
    ]
};
---
<Layout
    title={pageTitle}
    lang={lang}
    description={pageDescription}
    image={pageImage}
    schema={schema}
    canonicalPath={`/${lang}/${category}`}
>
    <HeroCategory lang={lang} category={category} />
    <Products lang={lang} products={products?.data || null} category={category} />
    <Questions lang={lang} />
</Layout>


<script>
    import AOS from 'aos';
    
    AOS.init({
        duration: 800,
        once: true,
        offset: 100,
    });
    
</script>