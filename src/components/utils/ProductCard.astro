---
import type { Lang } from '../../i18n/config.i18n';

interface Product {
  id?: number;
  name: string;
  slug: string;
  sku: string;
  categories: string[];
  image: string;
}

interface Props {
  product: Product;
  lang: Lang;
  category?: string;
  index?: number;
  viewProductLabel: string;
  buyOnAmazonLabel: string;
  findStoreLabel: string;
  cardClass?: string;
  imageWrapperClass?: string;
}

const {
  product,
  lang,
  category,
  index = 0,
  viewProductLabel,
  buyOnAmazonLabel,
  findStoreLabel,
  cardClass = 'bg-white p-5 rounded-2xl border border-gray-100 flex flex-col justify-between items-center text-center transition-all duration-300',
  imageWrapperClass = 'w-full h-80 flex items-center justify-center mb-4 overflow-hidden rounded-2xl'
} = Astro.props;
---

<div
  data-aos="fade-up"
  data-aos-delay={200 + index * 100}
  class={cardClass}
>
  <div class={imageWrapperClass}>
    <img
      src={product.image}
      class="max-h-full object-contain hover:scale-105 transition-transform duration-300"
      alt={product.name}
    />
  </div>

  <div class="w-full grow flex flex-col justify-start mb-6 min-w-0">
    <h3 class="font-bold text-base text-neutral-800 line-clamp-2 wrap-anywhere">{product.name}</h3>
  </div>

  <div class="w-full flex flex-col gap-2 mt-auto">
    <a
      href={category ? `/${lang}/${category}/${product.slug}` : '#'}
      class="w-full py-2.5 px-4 bg-green-cancun hover:opacity-90 text-white font-semibold text-xs rounded-lg transition-colors flex items-center justify-center gap-2"
    >
      {viewProductLabel}
    </a>
    <a
      href="#"
      class="w-full py-2.5 px-4 bg-[#E50012] hover:bg-red-700 text-white font-medium text-xs rounded-lg transition-colors flex items-center justify-center gap-2"
    >
      {buyOnAmazonLabel}
    </a>
    <a
      href="#"
      class="w-full py-2.5 px-4 bg-[#FFCC00] hover:bg-yellow-500 text-neutral-900 font-semibold text-xs rounded-lg transition-colors flex items-center justify-center gap-2"
    >
      {findStoreLabel}
    </a>
  </div>
</div>
