---
import type { HTMLAttributes } from 'astro/types';


interface Props extends HTMLAttributes<'input'> {
    label?: string
    color?: string
    ref:   string
    name?: string
    icon?: any
}

const { label, color = "green-cancun", ref, name, icon: Icon, ...rest  } = Astro.props;
---


<div class="flex flex-col w-full">
    {
        label ? (
            <label for={ref} class={`text-${color} font-bold mb-1`}>
                {label}
            </label>
        ) : null
    }
    
    <div class="relative flex items-center w-full">
        {Icon && (
            <div class=`absolute left-3 text-${color} pointer-events-none`>
                <Icon size={18} /> 
            </div>
        )}

        <input 
            id={ref} 
            name={name ?? ref} 
            {...rest}  
            class={`bg-gray-real p-2 w-full outline-none ${Icon ? 'pl-10' : 'pl-3'}`}
        />
    </div>
</div>