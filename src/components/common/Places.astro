---
export interface Place {
    id: string;
    name: string;
    address: string;
    zipCode: string;
}

export interface Props {
    title: string;
    description: string;
    placeholder: string;
    textButton: string;
    places: Place[];
}

const { title, description, placeholder, textButton, places } = Astro.props;
import Input from '../utils/Input.astro';
import { Map } from 'lucide-astro';
---

<div class="w-full mx-auto font-sans px-4 md:px-10">
    {/* Contenedor principal con el gradiente y bordes redondeados */}
    <div class="relative bg-gradient-to-r from-[#df1b23] via-[#f04f23] to-[#fed10a] p-10 md:p-20 rounded-2xl flex flex-col md:flex-row items-center justify-between gap-8 overflow-hidden shadow-lg border border-transparent">
        
        {/* Detalle visual sutil en la esquina superior derecha (decorativo) */}
        <div class="absolute top-0 right-0 h-full w-48 bg-yellow-300 opacity-20 rounded-l-full mix-blend-overlay pointer-events-none translate-x-12"></div>
        
        {/* Lado Izquierdo: Textos */}
        <div class="w-full md:w-1/2 z-10 flex flex-col justify-center">
            {/* El max-w-[280px] ayuda a forzar el salto de línea para que "Oasis" quede abajo */}
            <h2 class="text-white text-5xl md:text-6xl font-bold mb-4 leading-[1.05] tracking-tight max-w-[280px]">
                {title}
            </h2>
            <p class="text-white text-base md:text-lg font-light max-w-sm opacity-95">
                {description}
            </p>
        </div>
        <form id="place-search-form" data-places={JSON.stringify(places)} class="w-full md:w-1/2 z-10 flex md:justify-end">
            {/* Contenedor principal: Columna en móvil (gap-3), Fila y forma de "píldora" en PC */}
            <div class="flex flex-col md:flex-row items-center w-full max-w-lg md:bg-white md:rounded-full md:p-1.5 md:shadow-md gap-3 md:gap-0">
                
                {/* Sección del Icono + Input */}
                {/* Móvil: Fondo blanco independiente. PC: Fondo transparente (usa el fondo del padre) */}
                <div class="flex items-center bg-white md:bg-transparent rounded-full p-1.5 md:p-0 w-full flex-1 shadow-md md:shadow-none">
                    <Input id="place-input" ref="places" placeholder={placeholder} type="text" icon={Map} />
                </div>
                
                {/* Botón */}
                {/* Móvil: w-full (ancho completo). PC: w-auto (se ajusta a su contenido) */}
                <button type="submit" class="w-full md:w-auto bg-green-cancun hover:bg-green-cancun-700 text-white font-semibold text-sm md:text-base py-3 px-8 rounded-full transition-colors duration-200 shadow-md md:shadow-none">
                    {textButton}
                </button>
            </div>
        </form>

    </div>
</div>

<script>
    const form = document.getElementById('place-search-form') as HTMLFormElement;

    if (form) {
        form.addEventListener('submit', (e) => {
            e.preventDefault(); // Evitamos que la página se recargue

            // Buscamos el input dentro del formulario. 
            // Usar querySelector('input') es más seguro por si tu componente <Input /> no está renderizando el ID correctamente.
            const input = form.querySelector('input') as HTMLInputElement;

            if (input && input.value.trim() !== '') {
                const zipcodeValue = input.value.trim();

                // Aquí decides cómo quieres que se llame el parámetro en la URL.
                // Esto generará: #places?zipcode=90210
                window.location.hash = `places?zipcode=${zipcodeValue}`;
                
                // NOTA: Si necesitas que el parámetro se llame "places" como en tu ejemplo anterior, usa esta línea en su lugar:
                // window.location.hash = `places?places=${zipcodeValue}`;
            }
        });
    }
</script>