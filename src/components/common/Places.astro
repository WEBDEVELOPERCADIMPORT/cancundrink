---
export interface Place {
    id: string;
    name: string;
    address: string;
    zipCode: string;
}

export interface Props {
    title: string;
    description: string;
    placeholder: string;
    textButton: string;
    places: Place[];
    searchedZipCode?: string | null;
    resultsTitle: string;
    noResultsPrefix: string;
    helperText: string;
    mapTitle: string;
}

const {
    title,
    description,
    placeholder,
    textButton,
    places,
    searchedZipCode = null,
    resultsTitle,
    noResultsPrefix,
    helperText,
    mapTitle
} = Astro.props;
import Input from '../utils/Input.astro';
import { Map } from 'lucide-astro';

const hasSearch = Boolean(searchedZipCode);
const hasResults = hasSearch && places.length > 0;

const mapQuery = hasResults
    ? places.map((place) => place.address).join(' | ')
    : searchedZipCode
      ? `${searchedZipCode} Quintana Roo`
      : 'Cancun Quintana Roo';

const mapEmbedSrc = `https://www.google.com/maps?q=${encodeURIComponent(mapQuery)}&output=embed`;
---

<div class="w-full mx-auto font-sans px-4 md:px-10">
    {/* Contenedor principal con el gradiente y bordes redondeados */}
    <div class="relative bg-linear-to-r from-[#df1b23] via-[#f04f23] to-[#fed10a] p-10 md:p-20 rounded-2xl flex flex-col gap-8 overflow-hidden shadow-lg border border-transparent">
        
        {/* Detalle visual sutil en la esquina superior derecha (decorativo) */}
        <div class="absolute top-0 right-0 h-full w-48 bg-yellow-300 opacity-20 rounded-l-full mix-blend-overlay pointer-events-none translate-x-12"></div>
        
        {/* Lado Izquierdo: Textos */}
        <div class="w-full z-10 grid grid-cols-1 md:grid-cols-2 items-center gap-8">
            <div class="w-full flex flex-col justify-center">
                {/* El max-w-70 ayuda a forzar el salto de línea para que "Oasis" quede abajo */}
                <h2 class="text-white text-5xl md:text-6xl font-bold mb-4 leading-[1.05] tracking-tight max-w-70">
                    {title}
                </h2>
                <p class="text-white text-base md:text-lg font-light max-w-sm opacity-95">
                    {description}
                </p>
            </div>
            <form id="places-search-form" method="GET" action="" class="w-full flex md:justify-end">
                <div class="flex flex-col md:flex-row items-center w-full max-w-lg md:bg-white md:rounded-full md:p-1.5 md:shadow-md gap-3 md:gap-0">
                    <div class="flex items-center bg-white md:bg-transparent rounded-full p-1.5 md:p-0 w-full flex-1 shadow-md md:shadow-none">
                        <Input id="zip-code-input" ref="zip-code-input" placeholder={placeholder} type="text" icon={Map} value={searchedZipCode ?? ''} />
                    </div>
                    <button type="submit" class="w-full md:w-auto bg-green-cancun hover:bg-green-cancun-700 text-white font-semibold text-sm md:text-base py-3 px-8 rounded-full transition-colors duration-200 shadow-md md:shadow-none">
                        {textButton}
                    </button>
                </div>
            </form>
        </div>

        <div class="relative z-10 w-full rounded-2xl bg-white/90 backdrop-blur-sm border border-white/60 p-4 sm:p-6 md:p-7">
            {hasSearch ? (
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 sm:gap-7 items-start">
                    <div>
                        <h3 class="text-black-cancun font-extrabold text-2xl sm:text-3xl mb-4 sm:mb-5 leading-tight wrap-anywhere">
                            {resultsTitle} ({places.length})
                        </h3>

                        {hasResults ? (
                            <ul class="space-y-3 sm:space-y-4">
                                {places.map((place) => (
                                    <li class="bg-white rounded-xl p-4 sm:p-5 border border-gray-100 shadow-sm">
                                        <a
                                            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(place.address)}`}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="font-bold text-base sm:text-lg text-black-cancun underline underline-offset-4 decoration-2 decoration-green-cancun hover:text-green-cancun transition-colors wrap-anywhere"
                                        >
                                            {place.name}
                                        </a>
                                        <p class="text-sm sm:text-base text-neutral-700 mt-2 wrap-anywhere">{place.address}</p>
                                        <p class="text-sm text-neutral-500 mt-1">ZIP: {place.zipCode}</p>
                                    </li>
                                ))}
                            </ul>
                        ) : (
                            <p class="text-neutral-700 text-base sm:text-lg">
                                {`${noResultsPrefix} ${searchedZipCode}.`}
                            </p>
                        )}
                    </div>

                    <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm bg-white min-h-96 sm:min-h-104">
                        <iframe
                            title={mapTitle}
                            src={mapEmbedSrc}
                            class="w-full h-96 sm:h-104"
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                        ></iframe>
                    </div>
                </div>
            ) : (
                <p class="text-neutral-700 text-base sm:text-lg">
                    {helperText}
                </p>
            )}
        </div>

    </div>
</div>

<script>
    const form = document.getElementById('places-search-form') as HTMLFormElement | null;

    const searchParams = new URLSearchParams(window.location.search);
    const zipFromSearch = searchParams.get('zipCode')?.trim();
    const hash = window.location.hash;

    if (!zipFromSearch && hash.startsWith('#places?')) {
        const hashParams = new URLSearchParams(hash.replace('#places?', ''));
        const zipFromHash = hashParams.get('zipCode')?.trim();

        if (zipFromHash) {
            window.location.replace(`${window.location.pathname}?zipCode=${encodeURIComponent(zipFromHash)}#places`);
        }
    }

    if (zipFromSearch && hash !== '#places') {
        const prettyUrl = `${window.location.pathname}?zipCode=${encodeURIComponent(zipFromSearch)}#places`;
        window.history.replaceState({}, '', prettyUrl);
    }

    if (form) {
        form.addEventListener('submit', (event) => {
            event.preventDefault();

            const input = document.getElementById('zip-code-input') as HTMLInputElement | null;
            const zipCode = input?.value.trim();

            if (!zipCode) {
                return;
            }
            
            window.location.assign(`${window.location.pathname}?zipCode=${encodeURIComponent(zipCode)}#places`);
        });
    }
</script>