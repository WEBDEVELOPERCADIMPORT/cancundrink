---
import { getLangFromUrl, useTranslations } from '../../i18n/utils.i18n';
import { Share2, Mail } from 'lucide-astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="w-full bg-black-cancun py-12 px-6 md:px-12 mt-10 text-white">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:justify-between md:items-center gap-8">
    
    <div class="flex flex-col max-w-xs gap-4">
      <img src="/logo_cancun.png" class="w-28 object-contain" alt="Cancún Drink Logo">
      <p class="text-xs text-gray-400 leading-relaxed">
        {t.footer.rights}
      </p>
    </div>

    <div class="grid grid-cols-2 gap-x-12 gap-y-3 text-sm font-medium text-gray-300">
      <a href={`/${lang}/#categories`} class="hover:text-white transition-colors">{t.footer.flavors}</a>
      <a href={`/${lang}/#places`} class="hover:text-white transition-colors">{t.footer.storeFinder}</a>
      <a href={`/${lang}/#skills`} class="hover:text-white transition-colors">{t.footer.sustainability}</a>
      <a href={`#questions`} class="hover:text-white transition-colors">{t.footer.faq}</a>
    </div>

    <div class="flex items-center gap-4">
      <a href="#" class="p-2 bg-zinc-800 rounded-full hover:bg-zinc-700 transition-colors" aria-label="Share">
        <Share2 />
      </a>
      <a href="#" class="p-2 bg-zinc-800 rounded-full hover:bg-zinc-700 transition-colors" aria-label="Contact">
        <Mail />
      </a>
    </div>

  </div>
</footer>