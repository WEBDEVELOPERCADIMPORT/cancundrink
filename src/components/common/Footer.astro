---
import { getLangFromUrl, useTranslations } from '../../i18n/utils.i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="w-full border-t border-white-cancun bg-black-cancun py-8 px-6 mt-10">
  <div class="max-w-7xl mx-auto flex flex-col items-start justify-center w-full">
    <img src="/logo_cancun.png" class="w-30" alt="">
  </div>
  <div>
    <p class="text-start text-sm text-gray-500 mt-4">
      {t.footer.rights}
    </p>
  </div>
</footer>