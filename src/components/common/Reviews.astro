---

export interface Review {
    name: string;
    comment: string;
    rating: number;
    date: string;
}

interface ReviewsProps {
    title: string;
    reviews: Review[] | null;
}

const title = Astro.props.title as ReviewsProps['title'];
const reviews = Astro.props.reviews as ReviewsProps['reviews'];
---

<div class="w-full max-w-6xl mx-auto py-12 px-1 sm:px-6 lg:px-8 font-sans">
    <header class="text-center mb-12 flex flex-col items-center justify-center">
        <h2 class="font-bold text-4xl text-gray-900 mb-6">{title}</h2>
        
        <div class="flex flex-col items-center gap-2">
            <div class="flex items-center gap-2 text-xl">
                <span class="font-bold text-black tracking-tight">amazon</span>
                <span class="text-gray-900 font-medium">Review</span>
            </div>
            
            <div class="flex items-center gap-2 mt-1">
                <span class="font-bold text-xl text-gray-900">4.89</span>
                <div class="flex text-yellow-400 gap-0.5">
                    {Array.from({ length: 5 }).map(() => (
                        <svg class="w-6 h-6 fill-current" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                    ))}
                </div>
                <span class="text-gray-400 font-medium text-lg ml-1">(89)</span>
            </div>
        </div>
    </header>

    <div class="relative group review-carousel-container">
        
        <button class="prev-btn absolute left-0 top-1/2 -translate-y-1/2 -ml-4 lg:-ml-6 z-10 bg-white rounded-full p-2 shadow-[0_2px_8px_rgba(0,0,0,0.1)] text-red-500 hover:bg-gray-50 hover:scale-105 transition-all focus:outline-none" aria-label="Anterior">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
            </svg>
        </button>

        <div class="review-track flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 pt-4 px-2 no-scrollbar scroll-smooth">
            {reviews?.map((review) => (
                <div class="snap-center shrink-0 w-[340px] md:w-[380px] bg-white border border-gray-100 rounded-[32px] p-8 shadow-[0_4px_24px_-8px_rgba(0,0,0,0.08)] flex flex-col justify-between">
                    <div>
                        <!-- Info del usuario -->
                        <div class="flex items-center gap-3 mb-6">
                                <div class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold text-xl">
                                    {review.name.charAt(0)}
                                </div>
                            <div class="flex flex-col">
                                <h3 class="font-bold text-gray-900 text-[15px] leading-tight">{review.name}</h3>
                                <p class="text-[13px] text-gray-500 mt-0.5">{review.date}</p>
                            </div>
                        </div>

                        <div class="flex items-center justify-end gap-1 mb-4">
                            <div class="flex text-yellow-400 gap-0.5">
                                {Array.from({ length: 5 }).map((_, i) => (
                                    <svg class={`w-4 h-4 ${i < review.rating ? 'fill-current' : 'text-gray-300 fill-current'}`} viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                ))}
                            </div>
                            <div class="bg-blue-500 rounded-full w-4 h-4 flex items-center justify-center ml-1">
                                <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                </svg>
                            </div>
                        </div>

                        <p class="text-[15px] text-gray-800 leading-relaxed font-medium">
                            {review.comment}
                        </p>
                    </div>

                </div>
            ))}
        </div>

        <button class="next-btn absolute right-0 top-1/2 -translate-y-1/2 -mr-4 lg:-mr-6 z-10 bg-white rounded-full p-2 shadow-[0_2px_8px_rgba(0,0,0,0.1)] text-red-500 hover:bg-gray-50 hover:scale-105 transition-all focus:outline-none" aria-label="Siguiente">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
        </button>

    </div>
</div>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script>
    // Lógica para inicializar múltiples carruseles si fuera necesario y manejar clics
    function setupCarousels() {
        const carousels = document.querySelectorAll('.review-carousel-container');
        
        carousels.forEach(container => {
            const track = container.querySelector('.review-track');
            const prevBtn = container.querySelector('.prev-btn');
            const nextBtn = container.querySelector('.next-btn');

            if (!track || !prevBtn || !nextBtn) return;

            // Cantidad a scrollear: Ancho de la tarjeta + gap aprox
            const scrollAmount = 380; 

            prevBtn.addEventListener('click', () => {
                track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
            });

            nextBtn.addEventListener('click', () => {
                track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
            });
        });
    }

    setupCarousels();
    
    // Soporte para Astro View Transitions (si las usas en tu proyecto)
    document.addEventListener('astro:page-load', setupCarousels);
</script>