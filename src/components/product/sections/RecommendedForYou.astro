---
import type { Lang } from '../../../i18n/config.i18n';
import content from '../../../data/site-product-content.json';
import ProductCard from '../../utils/ProductCard.astro';

interface Product {
  id?: number;
  name: string;
  slug: string;
  sku: string;
  categories: string[];
  image: string;
}

interface Props {
  lang: Lang;
  category: string;
  products: Product[];
}

const { lang, category, products } = Astro.props;
const data = content[lang].recommended;
---

<section id="recommended-products" class="w-full flex flex-col justify-center px-6 py-16 bg-white mx-auto">
  <header class="max-w-7xl mx-auto w-full mb-8">
    <h2 class="font-bold text-3xl md:text-4xl text-left text-neutral-800">{data.title}</h2>
  </header>

  <article class="max-w-7xl mx-auto w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 justify-center">
      {
        products.map((product, index) => (
          <ProductCard
            product={product}
            lang={lang}
            category={category}
            index={index}
            viewProductLabel={data.viewProduct}
            buyOnAmazonLabel={data.buyOnAmazon}
            findStoreLabel={data.findStore}
            cardClass="bg-gray-cancun p-5 rounded-2xl border border-gray-100 flex flex-col justify-between items-center text-center transition-all duration-300"
            imageWrapperClass="w-full h-80 flex items-center justify-center mb-4 overflow-hidden rounded-2xl bg-white"
          />
        ))
      }
    </div>
  </article>
</section>
