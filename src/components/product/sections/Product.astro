---
import { MoveLeft, TreePalm } from 'lucide-astro';
import type { Lang } from '../../../i18n/config.i18n';
import content from '../../../data/site-product-content.json';

interface Product {
  id?: number;
  name: string;
  slug: string;
  sku: string;
  categories: string[];
  image: string;
}

interface Props {
  lang: Lang;
  category: string;
  categoryTitle: string;
  product: Product;
}

const { lang, category, categoryTitle, product } = Astro.props;
const data = content[lang].product;
---

<section id="product-detail" class="w-full flex flex-col justify-center px-6 py-16 bg-gray-cancun mx-auto">
  <div class="max-w-7xl mx-auto w-full flex flex-wrap items-start gap-x-2 gap-y-1 mb-6">
    <MoveLeft class="w-6 h-6 md:w-8 md:h-8 text-green-cancun drop-shadow-md shrink-0" />

    <a href={`/${lang}/#categories`} class="text-sm md:text-base font-bold tracking-widest uppercase text-black-cancun drop-shadow-md hover:underline wrap-anywhere">
      {data.returnHome}
    </a>

    <a href={`/${lang}/${category}`} class="text-sm md:text-base font-bold tracking-widest uppercase text-black-cancun drop-shadow-md hover:underline wrap-anywhere">
      / {categoryTitle}
    </a>

    <span class="text-sm md:text-base font-bold tracking-widest uppercase text-black-cancun drop-shadow-md wrap-anywhere w-full md:w-auto">
      / {product.name}
    </span>
  </div>

  <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
    <div class="bg-white p-6 md:p-8 rounded-2xl border border-gray-100 flex items-center justify-center min-h-105">
      <img
        src={product.image}
        alt={product.name}
        class="max-h-105 w-auto object-contain hover:scale-105 transition-transform duration-300"
      />
    </div>

    <div class="flex flex-col">
      <div class="flex items-center gap-2 mb-4">
        <TreePalm class="w-6 h-6 text-green-cancun" />
        <span class="text-sm md:text-base font-bold tracking-widest uppercase text-black-cancun">
          {data.title}
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl font-extrabold text-black-cancun leading-tight mb-6 wrap-anywhere">
        {product.name}
      </h1>

      <div class="bg-white rounded-2xl border border-gray-100 p-5 md:p-6 space-y-4">
        <div>
          <p class="text-xs uppercase tracking-widest text-neutral-500 font-bold">{data.skuLabel}</p>
          <p class="text-xl md:text-2xl font-extrabold text-black-cancun">{product.sku}</p>
        </div>

        <div>
          <p class="text-xs uppercase tracking-widest text-neutral-500 font-bold">{data.categoryLabel}</p>
          <p class="text-lg md:text-xl font-bold text-black-cancun">{categoryTitle}</p>
        </div>
      </div>
    </div>
  </div>
</section>
