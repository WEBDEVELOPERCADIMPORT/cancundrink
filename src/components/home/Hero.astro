---
import type { Lang } from '../../i18n/config.i18n';
import content from '../../data/site-home-content.json';

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;

const data = content[lang].hero;
---

<section class="relative w-full h-[calc(100vh-4rem)] flex items-center justify-center">
    
    <video 
        class="absolute top-0 left-0 w-full h-full object-cover "
        autoplay 
        loop 
        muted 
        playsinline
    >
        <source src="/img/hero/playa.mp4" type="video/mp4" />
    </video>

    
    <div class="relative z-10 text-center px-6 grid grid-cols-1 md:grid-cols-2 w-full h-full py-20">
        <div class="flex flex-col justify-end md:justify-center items-center px-0 md:px-20 h-full">
            <div class="animate-in fade-in slide-in-from-left-5 duration-900">
                <h1 class="text-6xl xl:text-7xl  text-start font-bold text-white mb-4 text-shadow-2xs">{data.title}</h1>
                <p class="text-6xl xl:text-7xl  font-bold text-yellow-cancun text-start text-shadow-2xs">{data.subtitle}</p>
            </div>
        </div>
        <div class="flex flex-row justify-end md:justify-start items-center rounded-lg"> 
            <div class="flex justify-end items-end h-full">
                <img src="/img/utils/Cancun-hielera.png" class="w-80 md:w-50 flex justify-end items-start animate-in fade-in slide-in-from-botton-5 duration-500" alt="Hielera">
            </div>
            <div class="flex justify-end items-end h-full">
                <img src="/img/utils/coco.png" class="w-150 md:w-80 animate-in fade-in slide-in-from-botton-5 duration-900" alt="Coco">
            </div>
        </div>
    </div>

</section>