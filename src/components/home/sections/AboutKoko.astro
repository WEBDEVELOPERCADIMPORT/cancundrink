---
import type { Lang } from '../../../i18n/config.i18n';
import content from '../../../data/site-home-content.json';

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;

const data = content[lang].about;
---

<section id="about-koko"  class="bg-[url('/img/utils/banners/beach_overlay.png')] bg-cover bg-center w-full mt-20">
    <div class="flex flex-col px-10 justify-start h-full  bg-sky-500/80"> 
    <div class="relative z-10 text-center px-1 grid grid-cols-1 md:grid-cols-2 w-full h-full py-20 gap-20">
        <div class="flex flex-row md:flex-row justify-end md:justify-start items-center rounded-lg order-2 md:order-1"> 
            <div class="flex justify-end items-end h-full bg-white-cancun p-5 rounded-lg -rotate-5">
                
                <img 
                    id="koko-playa" 
                    src="/img/utils/koko_silla_playa.png" 
                    data-aos="fade-right" 
                    data-aos-delay="200" 
                    class="w-80 md:w-100 rotate-5 scale-125 md:scale-150 origin-bottom" 
                    alt="Koko-playa"
                >
            </div>
        </div>
        <div class="flex flex-col justify-end md:justify-center items-center px-0 md:px-20 h-full order-1 md:order-2">  
            <div 
            data-aos="fade-right"
            data-aos-delay="200"
            class="">
                <h2 class="text-6xl xl:text-7xl  text-start font-bold text-white mb-4 text-shadow-2xs">{data.title}</h2>
                <h2 class="text-6xl xl:text-7xl  font-bold text-yellow-cancun text-start text-shadow-2xs">{data.subtitle}</h2>
                <p class="text-white-cancun text-start text-shadow-2xs">{data.description}</p>
            </div>
        </div>
    </div>

</section>
