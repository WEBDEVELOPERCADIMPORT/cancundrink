---
import type { Lang } from '../../../i18n/config.i18n';
import content from '../../../data/site-home-content.json';
import { TreePalm  } from 'lucide-astro'

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;

const data = content[lang].skills;
import 'aos/dist/aos.css';
---

<section class="w-full flex-col justify-center px-5 py-20 bg-gray-cancun">
    
    <header class="text-center flex justify-center items-start">
        <h2 class="font-bold text-4xl text-center">{data.title}</h2>
    </header>

    <article class="w-full mt-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                data.skills.map((skill, index) => {
                    return (
                        <div 
                            data-aos="fade-up"
                            data-aos-delay={200 + index * 100}
                            class="group flex flex-col items-center text-center p-10 py-10 border border-white-cancun bg-white-cancun rounded-lg hover:scale-[1.02] transition-all duration-300 hover:shadow-xl cursor-pointer"
                        >
                            <header class="p-5 shadow-2xl rounded-full mb-3 transition-transform duration-300 group-hover:-translate-y-2 group-hover:scale-110">
                                <TreePalm class="w-12 h-12 text-green-cancun group-hover:text-green-500 transition-colors duration-300" />
                            </header>               
                            
                            <h3 class="font-semibold text-xl mb-2">{skill.title}</h3>
                            <p class="text-gray-500">{skill.description}</p>
                        </div>
                    )
                })
            }
        </div>
    </article>

</section>

